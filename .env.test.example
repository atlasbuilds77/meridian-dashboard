# E2E Test Environment
# Copy to .env.test and fill in values from `npm run test:create-session`

# Required: enables test auth bypass
TEST_MODE=true

# Generated by create-test-session.ts
TEST_SESSION_SECRET=your_generated_secret_here
TEST_USER_DB_ID=your_test_user_db_id_here

# Optional: override test port (default 3001)
# TEST_PORT=3001

# These are still needed for the app to start:
DATABASE_URL=postgresql://user:pass@localhost:5432/meridian
SESSION_SECRET=at-least-32-chars-for-session-secret-here
ENCRYPTION_KEY=at-least-32-chars-for-encryption-key-here
